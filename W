Set-StrictMode -Version Latest 
$ErrorActionPreference = "Stop"

$RepoName = "code_menu"
$UserName = "Johnsn0w"
# $BaseContentsUrl = "https://api.github.com/repos/Johnsn0w/code_menu/contents/"
$BaseApiUrl = "https://api.github.com/repos/$UserName/$RepoName/"
$BaseRawUrl = "https://raw.githubusercontent.com/$UserName/$RepoName/main/"
$ScriptEntryPoint = "powershell\main.ps1"

$IsDevEnv = $PSScriptRoot
# $SkipElevation = $true
$SkipElevation = $false


function DownloadRepoFiles(){
    $ZipPath = "${TempFilesPath}\.repo.zip"
    If (-not (Test-Path $ZipPath)) {
        New-Item -ItemType Directory -Path $TempFilesPath
        Invoke-RestMethod -Uri "https://api.github.com/repos/$USERNAME/$REPO/zipball" -OutFile $ZipPath
        Expand-Archive -Path $ZipPath -DestinationPath "$PSScriptRoot\ps_temp_files\"
    }
}

if(-not $IsDevEnv){
    Read-Host "trace"
    $TempFilesPath = "${env:TEMP}\ps_temp_files\"
    DownloadRepoFiles
    $NewDir = (Get-ChildItem -Path $TempFilesPath -Directory -Filter "${UserName}*").BaseName
    $RepoDir = "$TempFilesPath\$NewDir\" 
    $MainScript = "$RepoDir\$ScriptEntrypoint"
} else {
    $MainScript = "$PSScriptRoot\$ScriptEntryPoint"
}

If($SkipElevation){
    . $MainScript
}else{
    Set-Location "$PSScriptRoot\powershell"
    Start-Process powershell -ArgumentList "-NoExit -NoProfile -ExecutionPolicy Bypass -File `"$MainScript`"" -Verb RunAs
}
